# ── Database ───────────────────────────────────────────────
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb

# ── n8n ────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=admin123

# ── Embedding model: "huggingface" (free/local) or "openai" ─
EMBEDDING_MODEL=huggingface
HF_MODEL_NAME=all-MiniLM-L6-v2

# ── LLM provider: "ollama" (local) | "anthropic" | "openai" ─
LLM_PROVIDER=ollama
OLLAMA_MODEL=mistral

# ── Anthropic (leave blank if not using) ───────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── OpenAI (leave blank if not using) ──────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-3.5-turbo

# ── Chunking defaults ──────────────────────────────────────
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=100

# ── Retrieval defaults ─────────────────────────────────────
DEFAULT_TOP_K=5
SIMILARITY_THRESHOLD=0.35

# ── Slack (for n8n notifications - optional) ───────────────
SLACK_WEBHOOK_URL=
